    }
  },
  "quality_gates": [
    "代码必须通过 ESLint 检查",
    "单元测试覆盖率>80%",
    "代码必须有注释",
    "提交前必须自测通过"
  ],
  "tools": [
    "代码编辑器",
    "版本控制",
    "单元测试框架",
    "调试工具"
  ]
